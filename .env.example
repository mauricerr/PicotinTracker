# Notification channels are checked in this order: Telegram, Discord, Pushover, Email.
# Configure at least one for real alerts.

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
DISCORD_WEBHOOK_URL=

# Pushover
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Email via SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Monitor tuning
PICOTIN_CACHE_PATH=.state/picotin_seen.json
PICOTIN_SCREENSHOT_DIR=artifacts/screenshots
PICOTIN_LOG_PATH=logs/picotin-monitor.log
PICOTIN_DEDUPE_HOURS=6
PICOTIN_HEADLESS=true
PICOTIN_SECONDARY_COLORS=false
